{"element":{"atomicNumber":69,"symbol":"Tm","name":"Thulium","wikidataId":"Q1853","wikipediaTitle":"Thulium","wikipediaUrl":"https://en.wikipedia.org/wiki/Thulium","period":6,"group":null,"block":"f","category":"lanthanide","phase":"solid","mass":168.93422,"electronegativity":1.25,"ionizationEnergy":6.184,"radius":227,"summary":"Thulium is a chemical element; it has symbol Tm and atomic number 69. It is the thirteenth element in the lanthanide series of metals. It is the second-least abundant lanthanide in the Earth's crust, after radioactively unstable promethium. It is an easily workable metal with a bright silvery-gray luster. It is fairly soft and slowly tarnishes in air. Despite its high price and rarity, thulium is used as a dopant in solid-state lasers. It has no significant biological role and is not particularly toxic. Artificial radioactive isotopes of thulium are used as radiation sources in some portable X-ray devices.","neighbors":["Er","Yb"],"rankings":{"mass":50,"electronegativity":74,"ionizationEnergy":69,"radius":31,"density":29,"meltingPoint":24,"boilingPoint":54,"halfLife":0},"sources":{"structured":{"provider":"PubChem","license":"public domain","url":"https://pubchem.ncbi.nlm.nih.gov/element/69"},"identifiers":{"provider":"Wikidata","license":"CC0 1.0","url":"https://www.wikidata.org/wiki/Q1853"},"summary":{"provider":"Wikipedia","title":"Thulium","url":"https://en.wikipedia.org/wiki/Thulium","license":"CC BY-SA 4.0","accessDate":"2026-03-30"}},"discoveryYear":1879,"discoverer":"Per Teodor Cleve","etymologyOrigin":"place","etymologyDescription":"Thule, ancient name for Scandinavia","density":9.32,"meltingPoint":1818,"boilingPoint":2223,"halfLife":null},"group":null,"anomalies":[{"slug":"f-block-gap","label":"f-block discontinuity","elementCount":28}],"nav":{"prevInGroup":null,"nextInGroup":null,"prevInPeriod":{"symbol":"Er","name":"Erbium"},"nextInPeriod":{"symbol":"Yb","name":"Ytterbium"},"prevInBlock":{"symbol":"Er","name":"Erbium"},"nextInBlo