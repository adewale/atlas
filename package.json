{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:data": "tsx scripts/derive-data.ts",
    "build:seed": "tsx scripts/generate-seed.ts",
    "build": "npm run build:data && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:links": "tsx scripts/lint-internal-links.ts",
    "lint:colors": "tsx scripts/lint-color-tokens.ts",
    "lint:assertions": "tsx scripts/lint-non-null-assertions.ts",
    "lint:animations": "tsx scripts/lint-animation-tokens.ts",
    "lint:all": "npm run lint && npm run lint:links && npm run lint:assertions && npm run lint:animations",
    "deploy": "npm run build && wrangler pages deploy dist/"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fast-check": "^3.23.0",
    "globals": "^17.4.0",
    "jsdom": "^25.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
