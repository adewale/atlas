{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:data": "tsx scripts/derive-data.ts",
    "build:seed": "tsx scripts/generate-seed.ts",
    "build": "npm run build:data && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "node scripts/run-playwright.mjs",
    "profile:journeys": "node scripts/profile-journeys-http.mjs",
    "perf:audit": "node --expose-gc --import tsx scripts/perf-audit.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "deploy": "npm run build && wrangler pages deploy dist/"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "fast-check": "^3.23.0",
    "jsdom": "^25.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
